generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth v4 required tables) ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ────────────────────────────────────────────────────────────────────

enum Role {
  REP
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(REP)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  quotes   Quote[]
}

// ─── Product Catalog ──────────────────────────────────────────────────────────

enum ProductCategory {
  PANEL
  INVERTER
  BATTERY
  MOUNTING
  ACCESSORY
  EV_CHARGER
  // PAC (Pompe à Chaleur / Heat Pump) — mirrors the 9 Excel quote sections
  PAC_MACHINE      // heat pump unit (BUDERUS, VAILLANT)
  PAC_ACCESSORY    // vase d'expansion, vanne, robinets
  PAC_ELECTRICITE  // résistance, câblage
  PAC_MACONNERIE   // carrotage, tranchée, démolition
  PAC_ISOLATION    // tube standard
  PAC_CITERNE      // old oil tank removal
  PAC_CONDUITE     // piping (DN42, frigo, suppérieur)
  PAC_MONTAGE      // montage et mise en service (labor days)
  PAC_ADMIN        // démarche administrative, permits
  PAC_TANK         // hot-water (DHW) tanks, heating buffer tanks, combined tanks
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ProductCategory
  // Cost in Rappen (CHF cents) — integer, never float
  costRappen  Int
  // Watt-peak for panels, VA for inverters, Wh for batteries; null for other categories
  powerWp     Int?
  // Labor cost in Rappen per unit — used for PAC products where labor is itemized separately
  // from material (e.g. machine installation, piping labor per meter). Null = no labor.
  laborRappen Int?
  /// PAC machine installation context — 'interior' (e.g. PAC sol/eau in basement)
  /// or 'exterior' (e.g. PAC air/eau outside unit). Drives the
  /// "Pompe à chaleur intérieure/extérieure" checkbox on Vaud annonce
  /// form. Null for non-PAC products.
  installType String?
  /// Acoustic power level in dB(A) measured at 2°C outdoor reference temperature.
  /// Required input for OPB (Ordonnance sur la protection contre le bruit)
  /// compliance check + the "fiche technique" requirement of cantonal forms.
  /// Sourced from manufacturer datasheet. Null for non-PAC products.
  acousticPowerDb2C Float?
  /// Refrigerant type ('R32', 'R290', 'R410A', etc.) — drives Formulaire 75
  /// (Déclaration HFC) generation. R290 (propane) is HFC-free; R32 and
  /// R410A are HFC-stable and require the declaration. Null = unknown
  /// or not a PAC.
  refrigerantType String?
  /// Manufacturer brand name ('Alpha Innotec', 'Buderus', 'Vaillant', etc.).
  /// Free text — used for filtering catalog by supplier and rendering in
  /// quote line items. Null for generic/legacy products.
  manufacturer String?
  /// Manufacturer model code ('Hybrox 11', 'SWCV 92H3', 'TPS 250', etc.).
  /// Distinct from `name` which may include marketing text. Null = unknown.
  modelCode String?
  /// Nominal thermal output in kW at standard rating point (B0/W35 for
  /// geothermal, A7/W35 for air-water). PAC_MACHINE only — used for
  /// matching against required heating power from heat-load calc.
  thermalKwNominal Float?
  /// Coefficient of Performance at nominal rating point. PAC_MACHINE only.
  /// Used for energy efficiency labelling and EN-VD-72 (part renouvelable).
  copNominal Float?
  /// Total tank capacity in liters. PAC_TANK only — for DHW tanks (e.g.
  /// 300, 400L), buffer tanks (120L), and combined tanks (525L total).
  tankCapacityL Int?
  /// Tank type: 'dhw' (hot water only), 'buffer' (heating buffer only),
  /// or 'combined' (both DHW + buffer in one unit, e.g. WWSP 404).
  /// PAC_TANK only.
  tankType String?
  /// For combined tanks (tankType='combined'): buffer portion capacity
  /// in liters; `tankCapacityL` then represents the total. Null for
  /// pure DHW or pure buffer tanks.
  bufferCapacityL Int?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  quoteItems QuoteItem[]
}

// ─── Cost Options (scaffolding, cable runs, complexity surcharges, etc.) ──────

model CostOption {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Fixed surcharge in Rappen
  costRappen  Int
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quoteScenarioOptions QuoteScenarioOption[]
}

// ─── Swiss Rates (ZIP → canton → electricity rate) ────────────────────────────

model SwissRate {
  id       String @id @default(cuid())
  canton   String // e.g. "ZH", "BE", "GE"
  // ZIP lookup key: full 4-digit NPA for municipality-level rows (seeded from
  // prisma/zip_energy_2026.json), or 2-digit canton prefix for fallback rows.
  zipPrefix String
  // Retail electricity rate (H4 profile) in centimes per kWh (integer)
  rateRappenPerKwh Int
  /// Feed-in tariff (rétribution de l'injection) in ct/kWh, 2026 — from the
  /// ElCom sunshine dataset (tariffEH4) of the ZIP's majority grid operator.
  /// Null when the operator publishes no tariff. Decimals preserved (e.g. 14.038).
  feedInRappenPerKwh Float?
  /// Grid operator serving the majority of communes in this ZIP (e.g.
  /// "Romande Energie SA"). Shown to the rep as provenance for the rates.
  operatorName String?
  /// Representative commune name for this ZIP (from the swisstopo PLZ register).
  communeName String?

  @@unique([canton, zipPrefix])
  @@index([zipPrefix])
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  zip       String?
  canton    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes Quote[]

  // Index for fast search by email (most reliable identifier)
  @@index([email])
  @@index([name])
}

// ─── Quotes ───────────────────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

/// AI-proposed tier for a QuoteScenario. NULL for non-AI quotes (rep built
/// the scenario manually). Set on all 3 scenarios when the AI quote builder
/// produces tiered proposals (Essentiel / Recommandé / Premium).
///
/// Used by /present/[shareToken] Screen 2 to render the 3 swipeable tier
/// cards. Display order is essentiel(0) → recommande(1) → premium(2),
/// canonical via `sortOrder` (set at save time).
enum ScenarioTier {
  essentiel
  recommande
  premium
}

model Quote {
  id          String      @id @default(cuid())
  // Human-readable: QUO-2026-0001
  quoteNumber String      @unique
  status      QuoteStatus @default(DRAFT)
  repId       String
  // FK to Customer entity. Nullable for Phase 1 transition — backfill script
  // populates this from denormalized fields. New quotes always set customerId.
  customerId  String?
  // Customer info — DENORMALIZED (kept for Phase 1.5 rollback safety; will be
  // dropped in a later phase once Customer FK is fully wired through the UI)
  customerName    String?
  customerEmail   String?
  customerZip     String?
  customerCanton  String?
  // Address for site
  siteAddress String?
  customerPhone String?
  // Map position for aerial/satellite view in PDF
  mapLat  Float?
  mapLon  Float?
  mapZoom Int?
  notes       String?     @db.Text
  // Lifecycle timestamps — drive dashboard KPIs and follow-up reminders
  sentAt      DateTime?   // when the quote was first marked SENT (email or manual)
  expiresAt   DateTime?   // offer validity end-date (defaults to sentAt + 30 days at send)
  followUpAt  DateTime?   // next follow-up due (rep-set or auto-scheduled)
  // Customer response — set via the public /q/[token] route. acceptedAt is the
  // moment the customer clicked "Accepter"; declinedAt is the same for decline.
  // declineReason captures optional context the customer provided.
  acceptedAt    DateTime?
  declinedAt    DateTime?
  declineReason String?     @db.Text
  // Public share URL token. Generated on first SENT transition (or backfilled
  // from `id` for legacy quotes during migration). Decoupled from `id` so the
  // rep can revoke a leaked link without rebuilding the quote: set to null or
  // rotate the value, and the old URL stops resolving. NULL on DRAFT quotes
  // (never been sent).
  shareToken    String?     @unique
  // Customer-engagement tracking — driven by the public /q/[token] page.
  // firstViewedAt: timestamp the customer first opened the public link.
  //                Stays null until the link is opened.
  // viewCount    : incremented on every page load of /q/[token]; lets the
  //                rep see "viewed 3x" as a follow-up signal.
  firstViewedAt DateTime?
  viewCount     Int         @default(0)
  /// Rep-chosen hero scenario for /present Screen 3/4 (« vos chiffres » +
  /// « et si vous ne faites rien ? »). Null = automatic pick (recommandé →
  /// premium → first). Points at a QuoteScenario id belonging to this quote;
  /// stale ids (scenario re-created on edit) fall back to the automatic pick.
  heroScenarioId String?
  /// Cantonal building registration number (No ECA in Vaud, EGID in
  /// federal RegBL). Rep-entered, required on cantonal permit forms.
  /// Null on legacy quotes and DRAFTs that haven't reached permit-pack
  /// generation yet.
  noEca           String?
  /// Building type / affectation ('maison_individuelle', 'immeuble',
  /// 'mixte', 'commercial'). Drives "Affectation bâtiment" field on
  /// Vaud annonce form and EN-VD-3.
  buildingAssignment String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  rep         User            @relation(fields: [repId], references: [id])
  customer    Customer?       @relation(fields: [customerId], references: [id])
  scenarios   QuoteScenario[]
  /// One heat-load input per quote (the building's heat demand doesn't
  /// vary between PAC scenarios — same building, different machines).
  /// Drives EN-VD-3 + dimensioning of all PAC scenarios.
  heatLoadInput HeatLoadInput?

  @@index([repId])
  @@index([status])
  @@index([followUpAt])
  @@index([customerId])
}

model QuoteScenario {
  id      String @id @default(cuid())
  quoteId String
  name    String @default("Szenario 1")
  // Discriminates PV (photovoltaic) vs PAC (pompe à chaleur / heat pump) scenarios.
  // Determines which pricing engine and UI are used.
  scenarioType String @default("PV")
  // Margin the rep set (basis points, e.g. 2500 = 25.00%)
  marginBasisPts Int
  // VAT snapshotted at save time (basis points, e.g. 810 = 8.10%)
  vatPctBasisPts Int
  // Electricity rate used for ROI calc (Rappen/kWh, snapshotted)
  rateRappenPerKwh Int?
  sortOrder Int      @default(0)
  roofType  String?  @default("tuile")
  roofSlope String?  @default("simple")
  // Computed price snapshotted at save time — ensures PDF re-generation shows
  // the same price that was quoted, even if admin changes pricing coefficients later.
  // NULL for quotes saved before this field was added (PDF falls back to live computation).
  sellingPriceExVatRappen  Int?
  sellingPriceIncVatRappen Int?
  // PVGIS yield factor snapshotted at save time (kWh/kWp/year).
  // NULL = falls back to 950 (Swiss average).
  yieldKwhPerKwp           Int?
  // ROI split: self-consumption vs. grid export
  // selfConsumptionRatePct: integer percentage (e.g. 40 = 40%). NULL = legacy (100% at retail).
  selfConsumptionRatePct   Int?
  // Feed-in tariff paid by utility for exported solar (Rappen/kWh). NULL = legacy.
  feedInRateRappenPerKwh   Int?
  // Annual household consumption used to derive SCR (kWh/year). NULL = not provided.
  annualConsumptionKwh     Int?
  // Rep-chosen discount applied to the engine-computed price (basis points;
  // 500 = 5%). Defaults to 0 (no discount). Capped server-side so effective
  // margin never falls below min_margin_basis_pts unless requiresApproval is
  // set and discountReason is captured.
  discountBasisPts         Int      @default(0)
  // Free-text reason required when the discount pushes effective margin below
  // min_margin_basis_pts. Captured for audit and analytics ("price
  // pressure", "volume", "competitive bid").
  discountReason           String?  @db.Text
  // True when discount drops effective margin below min_margin_basis_pts —
  // surfaces in admin queue for sign-off. False otherwise.
  requiresApproval         Boolean  @default(false)
  // Customer-facing 4-line breakdown snapshotted at save time. Null on
  // pre-Phase-2 quotes — PDF falls back to single "Total HT" line in that
  // case. Sum (equipment + installation + services + margin) === sellingPriceExVatRappen.
  // Margin is hidden on the customer PDF; the other three are visible.
  equipmentRappen          Int?
  installationRappen       Int?
  servicesRappen           Int?
  marginRappen             Int?
  /// AI-proposed tier ('essentiel' | 'recommande' | 'premium'). NULL on
  /// non-AI quotes (rep built the scenario manually) and on legacy quotes
  /// from before this column was added. Set on all 3 scenarios when the
  /// AI builder produces tiered proposals.
  ///
  /// Used by /present/[shareToken] Screen 2 to render the 3 tier cards.
  /// Filter: `WHERE tier IS NOT NULL` to get the AI-proposed scenarios.
  tier                     ScenarioTier?
  /// Heat-load result applied to this PAC scenario (kW thermal).
  /// Distinct from `installedKwp` which is PV peak power — different
  /// physical concept. Populated by the rep's "Apply" action in the
  /// heat-load modal; can diverge from the linked HeatLoadInput's
  /// computed value if the rep manually adjusted (e.g. rounded up
  /// for next-larger machine size).
  /// Null on PV scenarios and PAC scenarios pre-heat-load-calc.
  thermalLoadKw            Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote   Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  items   QuoteItem[]
  options QuoteScenarioOption[]

  @@index([quoteId])
}

/// Heat-load calculation input — one row per Quote (1:1). Captures the
/// rep's entry of building data (climate region, m², fuel history, current
/// generator) used by the suissetec V6.6 methodology to compute the
/// building's thermal demand. The result lives in `computedHeatLoadKw`
/// and feeds EN-VD-3 (Justificatif des mesures énergétiques — chauffage),
/// plus drives the rep's PAC machine selection via the per-scenario
/// `thermalLoadKw` (rep-confirmed).
///
/// Per-Quote (not per-scenario) because the math depends on building
/// data, not on which PAC machine is being quoted. Three PAC variants
/// for the same building share one HeatLoadInput.
///
/// `consumptionYears` is JSON [{year:Int, djc:Float, consumption:Float}]
/// — typically 3 entries from the last 3 heating seasons. JSON instead
/// of a separate model because we never query into it (it's an opaque
/// snapshot for the calc).
model HeatLoadInput {
  id                  String   @id @default(cuid())
  quoteId             String   @unique
  /// Swiss meteo station name (e.g. "Lausanne-Pully", "Payerne",
  /// "Neuchâtel"). Whitelisted against `lib/heat-load/climate-data.ts`
  /// at the API boundary.
  climateRegion       String
  /// Building type — drives operating-hours lookup. Values:
  /// 'maison_individuelle' | 'immeuble' | 'mixte'.
  buildingType        String
  /// Surface de référence énergétique in m².
  energyAreaM2        Int
  /// Hot water source — 'with_heating' | 'separate_pac' | 'separate_electric'.
  /// Drives the suissetec operating-hours lookup table (different rows
  /// for shared vs separate DHW).
  hotWaterSource      String
  /// Current fuel type — 'mazout_l' | 'gaz_m3' | 'pellets_kg' | 'electrique_kwh' | 'bois_ster_fichte' | 'bois_ster_buche'.
  /// Drives the caloric value + DJC-normalization formula.
  fuelType            String
  /// Current generator type — e.g. 'chaudiere_mazout_ancien',
  /// 'chaudiere_mazout_neuf', 'chaudiere_gaz_condensation', 'pellets',
  /// 'electrique_direct'. Drives the efficiency lookup.
  generatorType       String
  /// 3-year consumption history (snapshotted from rep entry).
  /// Shape: Array<{year: number, djc: number, consumption: number}>
  /// where `djc` is the heating-degree-day value for the climate region
  /// in that year and `consumption` is the rep-entered fuel usage.
  consumptionYears    Json
  /// Result of `calculateHeatLoadKw(input)` cached at save time.
  /// Recomputed on every PUT; cleared if input fields change. Null on
  /// pre-Phase-1 rows (none expected; this model is born in Phase 1).
  computedHeatLoadKw  Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  quote               Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model QuoteItem {
  id         String @id @default(cuid())
  scenarioId String
  productId  String
  quantity   Int    @default(1)
  // Material cost snapshotted at save time (Rappen) — protects history if catalog changes
  costRappenSnapshot Int
  // Labor cost snapshotted at save time (Rappen) — PAC only; null for PV items
  laborRappenSnapshot Int?

  scenario QuoteScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])
}

model QuoteScenarioOption {
  id         String @id @default(cuid())
  scenarioId String
  optionId   String
  // Cost snapshotted at save time (Rappen)
  costRappenSnapshot Int

  scenario QuoteScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  option   CostOption    @relation(fields: [optionId], references: [id])
}

// ─── App Settings (admin-managed singletons) ──────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Rate limiting (DB-backed counters) ───────────────────────────────────────

/// Per-key sliding-window counter consumed by `lib/rate-limit.ts`.
///
/// Key format is conventionally `{namespace}:{identifier}`, e.g.
///   "ai:user:cmf9..."   — AI parse calls per user per day
///   "respond:tok:abc..." — public quote respond per token per minute
///
/// Replaces the per-route in-memory `Map` rate limiters, which lost state on
/// every Vercel cold start (50 calls/day promise was unenforceable in
/// practice). DB-backed counters survive cold starts and scale across
/// concurrent Lambda instances.
///
/// Cleanup: rows are upserted in-place when the window rolls. Old rows that
/// no one queries again can stay around — they're tiny. A periodic prune of
/// `resetAt < now() - 7d` keeps the table small (cron, future work).
model RateBucket {
  key      String   @id
  count    Int
  /// Unix timestamp at which `count` resets to 0 on the next call.
  resetAt  DateTime

  @@index([resetAt])
}
